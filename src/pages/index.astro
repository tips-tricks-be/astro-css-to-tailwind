---
import CssConverter from '../components/CssConverter.astro';

import '.././styles/global.css'
---

<html lang="nl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>CSS naar Tailwind Converter</title>
	</head>
	
	<body class="bg-slate-950 font-sans font-wrapper">
		<main class="converter-container">
			<CssConverter />
		</main>
	</body>
</html>

<style is:global>
	/* Reset en dwing de html/body naar de volledige schermhoogte */
	html, body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100% !important;
		background-color: #020617; /* Slate-950 */
		overflow-x: hidden; /* Voorkom zijwaartse scrollbalken */
	}

	/* De body fungeert als de absolute basis die alles centreert */
	.font-wrapper {
		display: flex !important;
		justify-content: center !important;
		align-items: center !important;
		min-height: 100vh !important;
	}

	/* De main wrapper zorgt ervoor dat de brede box netjes gecentreerd blijft en niet plakt */
	.converter-container {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		padding: 24px; /* Geeft wat ademruimte aan de randen van het scherm */
		box-sizing: border-box;
	}
</style>