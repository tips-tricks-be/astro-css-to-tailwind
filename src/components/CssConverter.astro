---
// Ultieme CSS naar Tailwind Converter met Kopieerknop en Groot Woordenboek
import '.././styles/global.css'
---

<div class="max-w-7xl mx-auto my-12 p-8 bg-linier-to-br from-slate-900 to-slate-950 rounded-2xl shadow-2xl border border-slate-800 backdrop-blur-md">
  
  <div class="text-center mb-8">
    <h2 class="text-white !importan font-bold text-25px max-w-md mx-auto opacity-90">
      CSS naar Tailwind Converter
    </h2>
    <p class="text-white !important font-bold text-larger">
      Plak je traditionele CSS-regels links en tover ze direct om in kant-en-klare Tailwind utility classes.
    </p>
  </div> 
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    
    <div class="flex flex-col">
      <div class="flex items-center justify-between mb-2 px-1">
        <label for="css-input" class="text-xs font-semibold uppercase tracking-wider text-slate-400 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-pink-500 animate-pulse"></span> Gewone CSS
        </label>
        <span class="text-[11px] text-slate-500 font-mono">Input</span>
      </div>
      <div class="relative group">
        <textarea 
          id="css-input" 
          rows="14" 
          class="w-full p-4 font-mono text-sm bg-slate-900/60 text-slate-200 border border-slate-700 rounded-xl focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 outline-none transition duration-200 resize-none shadow-inner group-hover:border-slate-600"
          placeholder="color: red;&#10;font-size: 16px;&#10;padding: 12px;&#10;display: flex;&#10;justify-content: center;"
        ></textarea>
      </div>
    </div>

    <div class="flex flex-col">
      <div class="flex items-center justify-between mb-2 px-1">
        <label for="tailwind-output" class="text-xs font-semibold uppercase tracking-wider text-slate-400 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span> Tailwind Classes
        </label>
        <button 
          id="copy-btn"
          class="text-[11px] bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white px-2.5 py-1 rounded transition duration-150 flex items-center gap-1 font-sans border border-slate-700"
        >
          <span>Kopieer</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
        </button>
      </div>
      <div class="relative">
        <textarea 
          id="tailwind-output" 
          rows="14" 
          readonly
          class="w-full p-4 font-mono text-sm bg-slate-950/80 text-cyan-400 border border-slate-800 rounded-xl outline-none resize-none shadow-inner cursor-default"
          placeholder="De gegenereerde Tailwind classes verschijnen hier..."
        ></textarea>
      </div>
    </div>
  </div>

  <div class="mt-8 flex flex-col items-center">
    <button 
      id="convert-btn"
      class="px-8 py-3.5 bg-linear-0-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white font-semibold rounded-xl shadow-lg shadow-blue-500/20 transition-all duration-200 ease-in-out transform hover:-translate-y-0.5 active:translate-y-0 active:scale-95 flex items-center gap-2 text-sm tracking-wide"
    >
      Converteer naar Tailwind 
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
    </button>
  </div>
</div>

<script>
  // GIGANTISCH UITGEBREID WOORDENBOEK (MAPPING)
  const tailwindMap: Record<string, string> = {
    // Colors & Backgrounds
    'color: red': 'text-red-500',
    'color: blue': 'text-blue-500',
    'color: green': 'text-green-500',
    'color: white': 'text-white',
    'color: black': 'text-black',
    'background-color: red': 'bg-red-500',
    'background-color: blue': 'bg-blue-500',
    'background-color: green': 'bg-green-500',
    'background-color: white': 'bg-white',
    'background-color: black': 'bg-black',
    'background-color: transparent': 'bg-transparent',
    
    // Font sizes
    'font-size: 12px': 'text-xs',
    'font-size: 14px': 'text-sm',
    'font-size: 16px': 'text-base',
    'font-size: 18px': 'text-lg',
    'font-size: 20px': 'text-xl',
    'font-size: 24px': 'text-2xl',
    'font-size: 32px': 'text-3xl',
    
    // Spacing (Padding)
    'padding: 4px': 'p-1',
    'padding: 8px': 'p-2',
    'padding: 12px': 'p-3',
    'padding: 16px': 'p-4',
    'padding: 20px': 'p-5',
    'padding: 24px': 'p-6',
    'padding: 32px': 'p-8',
    'padding-top: 8px': 'pt-2',
    'padding-top: 16px': 'pt-4',
    'padding-bottom: 8px': 'pb-2',
    'padding-bottom: 16px': 'pb-4',
    'padding-left: 8px': 'pl-2',
    'padding-left: 16px': 'pl-4',
    'padding-right: 8px': 'pr-2',
    'padding-right: 16px': 'pr-4',
    
    // Spacing (Margin)
    'margin: 0': 'm-0',
    'margin: 4px': 'm-1',
    'margin: 8px': 'm-2',
    'margin: 12px': 'm-3',
    'margin: 16px': 'm-4',
    'margin: 24px': 'm-6',
    'margin: auto': 'm-auto',
    'margin-top: 8px': 'mt-2',
    'margin-top: 16px': 'mt-4',
    'margin-bottom: 8px': 'mb-2',
    'margin-bottom: 16px': 'mb-4',
    
    // Layout & Display
    'display: flex': 'flex',
    'display: grid': 'grid',
    'display: block': 'block',
    'display: inline-block': 'inline-block',
    'display: inline': 'inline',
    'display: none': 'hidden',
    
    // Flexbox & Grid specifieke eigenschappen
    'flex-direction: row': 'flex-row',
    'flex-direction: column': 'flex-col',
    'flex-wrap: wrap': 'flex-wrap',
    'justify-content: center': 'justify-center',
    'justify-content: flex-start': 'justify-start',
    'justify-content: flex-end': 'justify-end',
    'justify-content: space-between': 'justify-between',
    'justify-content: space-around': 'justify-around',
    'align-items: center': 'items-center',
    'align-items: flex-start': 'items-start',
    'align-items: flex-end': 'items-end',
    'align-items: stretch': 'items-stretch',
    'grid-template-columns: repeat(2, minmax(0, 1fr))': 'grid-cols-2',
    'grid-template-columns: repeat(3, minmax(0, 1fr))': 'grid-cols-3',
    'grid-template-columns: repeat(4, minmax(0, 1fr))': 'grid-cols-4',
    
    // Gap (Tussenruimte bij flex/grid)
    'gap: 4px': 'gap-1',
    'gap: 8px': 'gap-2',
    'gap: 12px': 'gap-3',
    'gap: 16px': 'gap-4',
    'gap: 24px': 'gap-6',
    
    // Text alignment & weights
    'text-align: center': 'text-center',
    'text-align: left': 'text-left',
    'text-align: right': 'text-right',
    'text-align: justify': 'text-justify',
    'font-weight: bold': 'font-bold',
    'font-weight: normal': 'font-normal',
    'font-weight: 500': 'font-medium',
    'font-weight: 600': 'font-semibold',
    'font-weight: 700': 'font-bold',
    'font-style: italic': 'italic',
    'text-transform: uppercase': 'uppercase',
    'text-transform: lowercase': 'lowercase',
    'text-decoration: underline': 'underline',
    
    // Borders & Radius
    'border-radius: 2px': 'rounded-sm',
    'border-radius: 4px': 'rounded-md',
    'border-radius: 8px': 'rounded-lg',
    'border-radius: 12px': 'rounded-xl',
    'border-radius: 16px': 'rounded-2xl',
    'border-radius: 50%': 'rounded-full',
    'border-style: solid': 'border-solid',
    'border-width: 1px': 'border',
    'border-width: 2px': 'border-2',
    'border-width: 4px': 'border-4',
    
    // Width & Height
    'width: 100%': 'w-full',
    'height: 100%': 'h-full',
    'width: auto': 'w-auto',
    'height: auto': 'h-auto',
    
    // Shadows & Box-shadow
    'box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1)': 'shadow-sm',
    'box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1)': 'shadow',
    'box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1)': 'shadow-md',
    'box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1)': 'shadow-lg',
    
    // Transitions & Opacity
    'transition: all 0.2s': 'transition-all duration-200',
    'cursor: pointer': 'cursor-pointer',
    'opacity: 0': 'opacity-0',
    'opacity: 0.5': 'opacity-50',
    'opacity: 1': 'opacity-100'
  };

  const cssInput = document.getElementById('css-input') as HTMLTextAreaElement;
  const tailwindOutput = document.getElementById('tailwind-output') as HTMLTextAreaElement;
  const convertBtn = document.getElementById('convert-btn');
  const copyBtn = document.getElementById('copy-btn');

  // CONVERTEER LOGICA
  convertBtn?.addEventListener('click', () => {
    const cssCode = cssInput.value.trim();

    if (!cssCode) {
      tailwindOutput.value = "// Plak eerst wat CSS code in het linker venster!";
      return;
    }

    const lines = cssCode.split(/[;\n]/);
    const convertedClasses: string[] = [];

    lines.forEach(line => {
      // Schoonmaken van accolades en overtollige witruimtes
      const cleanLine = line.replace(/[{}]/g, '').trim().toLowerCase();
      
      if (cleanLine) {
        // Directe match zoeken
        if (tailwindMap[cleanLine]) {
          convertedClasses.push(tailwindMap[cleanLine]);
        } else {
          // Dynamische Fallbacks (Arbitrary values) voor custom pixels/waardes
          if (cleanLine.startsWith('padding:')) {
            const val = cleanLine.replace('padding:', '').trim();
            convertedClasses.push(`p-[${val}]`);
          } else if (cleanLine.startsWith('padding-top:')) {
            const val = cleanLine.replace('padding-top:', '').trim();
            convertedClasses.push(`pt-[${val}]`);
          } else if (cleanLine.startsWith('padding-bottom:')) {
            const val = cleanLine.replace('padding-bottom:', '').trim();
            convertedClasses.push(`pb-[${val}]`);
          } else if (cleanLine.startsWith('padding-left:')) {
            const val = cleanLine.replace('padding-left:', '').trim();
            convertedClasses.push(`pl-[${val}]`);
          } else if (cleanLine.startsWith('padding-right:')) {
            const val = cleanLine.replace('padding-right:', '').trim();
            convertedClasses.push(`pr-[${val}]`);
          } else if (cleanLine.startsWith('margin:')) {
            const val = cleanLine.replace('margin:', '').trim();
            convertedClasses.push(`m-[${val}]`);
          } else if (cleanLine.startsWith('margin-top:')) {
            const val = cleanLine.replace('margin-top:', '').trim();
            convertedClasses.push(`mt-[${val}]`);
          } else if (cleanLine.startsWith('margin-bottom:')) {
            const val = cleanLine.replace('margin-bottom:', '').trim();
            convertedClasses.push(`mb-[${val}]`);
          } else if (cleanLine.startsWith('background-color:')) {
            const val = cleanLine.replace('background-color:', '').trim();
            convertedClasses.push(`bg-[${val}]`);
          } else if (cleanLine.startsWith('color:')) {
            const val = cleanLine.replace('color:', '').trim();
            convertedClasses.push(`text-[${val}]`);
          } else if (cleanLine.startsWith('font-size:')) {
            const val = cleanLine.replace('font-size:', '').trim();
            convertedClasses.push(`text-[${val}]`);
          } else if (cleanLine.startsWith('width:')) {
            const val = cleanLine.replace('width:', '').trim();
            convertedClasses.push(`w-[${val}]`);
          } else if (cleanLine.startsWith('height:')) {
            const val = cleanLine.replace('height:', '').trim();
            convertedClasses.push(`h-[${val}]`);
          } else if (cleanLine.startsWith('border-radius:')) {
            const val = cleanLine.replace('border-radius:', '').trim();
            convertedClasses.push(`rounded-[${val}]`);
          } else {
            convertedClasses.push(`/* Niet herkend: ${cleanLine} */`);
          }
        }
      }
    });

    if (convertedClasses.length > 0) {
      tailwindOutput.value = convertedClasses.join(' ');
    } else {
      tailwindOutput.value = "// Kon geen herkenbare CSS regels vinden.";
    }
  });

  // KLEMBOARD KOPIEER LOGICA
  copyBtn?.addEventListener('click', async () => {
    const textToCopy = tailwindOutput.value.trim();
    
    if (!textToCopy || textToCopy.startsWith('//')) {
      return;
    }

    try {
      await navigator.clipboard.writeText(textToCopy);
      
      // Visuele feedback op de knop geven
      const originalText = copyBtn.innerHTML;
      copyBtn.innerHTML = `<span>Gekopieerd! ✔️</span>`;
      copyBtn.classList.add('bg-green-700', 'border-green-600', 'text-white');
      
      // Na 2 seconden de knop weer herstellen naar normaal
      setTimeout(() => {
        copyBtn.innerHTML = originalText;
        copyBtn.classList.remove('bg-green-700', 'border-green-600', 'text-white');
      }, 2000);
      
    } catch (err) {
      console.error('Kopiëren mislukt: ', err);
    }
  });
</script>